[Desktop Entry]
Type=Application
Name=VoidBrowser
GenericName=Web Browser
Comment=A keyboard-first web browser inspired by Omarchy, Zen Browser, and Vim
Exec=env python3 __INSTALL_DIR__/main.py %U
Icon=voidbrowser
Terminal=false
Categories=Network;WebBrowser;
StartupWMClass=VoidBrowser
StartupNotify=true
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
